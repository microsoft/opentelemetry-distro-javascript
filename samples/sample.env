# Azure Monitor (required for most samples)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Cloud Role (used by cloudRole.ts)
OTEL_SERVICE_NAME=my-service
OTEL_SERVICE_NAMESPACE=my-namespace
OTEL_SERVICE_INSTANCE_ID=my-instance

# Azure OpenAI (used by langchainInstrumentation.ts and openaiInstrumentation.ts)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_INSTANCE_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-06-01

# A365 observability (used by a365Export.ts and a365ManualScopes.ts)
# Auth token for the Agent365 observability API. In production use MSAL; samples read it directly.
A365_BEARER_TOKEN=
